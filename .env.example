# LangSmith 설정
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_PROJECT=your-project-name
LANGSMITH_API_KEY=your-langsmith-api-key-here

# ── OpenAI 호환 LLM (provider: "openai") ─────────────────────────────────────
# KISTI / LiteLLM proxy 등 OpenAI 호환 엔드포인트
# config.json이 없을 때 환경변수로 대체
OPENAI_API_BASE="https://aida.kisti.re.kr:10411/v1"
OPENAI_API_KEY="dummy"
KISTI_MODEL=kistillm

# LLM 파라미터 (선택사항, config.json 우선)
# LLM_TEMPERATURE=0.7
# LLM_TIMEOUT=120

# ── Anthropic (provider: "anthropic") ────────────────────────────────────────
# Claude 계열 모델 사용 시 필요
# config.json의 api_key 가 없으면 이 값을 사용
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Google (provider: "google") ───────────────────────────────────────────────
# Gemini 계열 모델 사용 시 필요
# config.json의 api_key 가 없으면 이 값을 사용
# GOOGLE_API_KEY=AIzaSy-your-key-here

# Sandbox backend: "docker" or "local"
# docker: Docker 컨테이너 격리 (프로덕션 권장)
# local: 로컬 파일시스템 + 셸 실행 (개발/테스트용)
SANDBOX_BACKEND=docker
